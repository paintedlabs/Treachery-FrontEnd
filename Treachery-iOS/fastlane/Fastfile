default_platform(:ios)

XCODEPROJ = "Treachery-iOS.xcodeproj"
SCHEME    = "Treachery-iOS"

platform :ios do

  # ── Testing ────────────────────────────────────────────

  desc "Run unit tests"
  lane :test do
    run_tests(
      project: XCODEPROJ,
      scheme: SCHEME,
      devices: ["iPhone 16"],
      code_coverage: true,
      result_bundle: true,
      output_directory: "./build/test_output",
      clean: true
    )
  end

  # ── Shared CI setup ──────────────────────────────────────

  # Writes the App Store Connect API key to a .p8 file and returns
  # the xcargs string needed for -allowProvisioningUpdates.
  # This lets xcodebuild resolve signing automatically on CI
  # (profiles, Push Notifications, etc.) without manual overrides.
  private_lane :ci_signing_xcargs do
    require "base64"
    api_key_path = File.join(Dir.tmpdir, "AuthKey_#{ENV['APP_STORE_CONNECT_KEY_ID']}.p8")
    File.write(api_key_path, Base64.decode64(ENV["APP_STORE_CONNECT_KEY"]))

    [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath '#{api_key_path}'",
      "-authenticationKeyID '#{ENV['APP_STORE_CONNECT_KEY_ID']}'",
      "-authenticationKeyIssuerID '#{ENV['APP_STORE_CONNECT_ISSUER_ID']}'"
    ].join(" ")
  end

  # ── Beta (TestFlight) ─────────────────────────────────

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if is_ci

    # Import distribution certificate into Fastlane's temp keychain
    if is_ci
      import_certificate(
        certificate_path: ENV["CERTIFICATE_PATH"],
        certificate_password: ENV["P12_PASSWORD"],
        keychain_name: "fastlane_tmp_keychain",
        keychain_password: ""
      )
    end

    # Fetch App Store Connect API key from environment
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY"],
      is_key_content_base64: true
    )

    # Auto-increment build number using App Store Connect
    current = latest_testflight_build_number(api_key: api_key)
    increment_build_number(
      build_number: current + 1,
      xcodeproj: XCODEPROJ
    )

    # Build — use -allowProvisioningUpdates on CI so xcodebuild
    # resolves profiles automatically (handles Push Notifications,
    # SPM packages, etc. without manual signing overrides)
    signing_args = is_ci ? ci_signing_xcargs : ""
    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./build",
      clean: true,
      xcargs: signing_args,
      export_xcargs: signing_args
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  # ── Release (App Store) ──────────────────────────────

  desc "Build and submit to App Store review"
  lane :release do
    setup_ci if is_ci

    # Import distribution certificate into Fastlane's temp keychain
    if is_ci
      import_certificate(
        certificate_path: ENV["CERTIFICATE_PATH"],
        certificate_password: ENV["P12_PASSWORD"],
        keychain_name: "fastlane_tmp_keychain",
        keychain_password: ""
      )
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY"],
      is_key_content_base64: true
    )

    # Increment build number
    current = latest_testflight_build_number(api_key: api_key)
    increment_build_number(
      build_number: current + 1,
      xcodeproj: XCODEPROJ
    )

    # Build
    signing_args = is_ci ? ci_signing_xcargs : ""
    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./build",
      clean: true,
      xcargs: signing_args,
      export_xcargs: signing_args
    )

    # Upload and submit for review
    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  # ── Utilities ────────────────────────────────────────

  desc "Register new device UDIDs"
  lane :register_devices_from_file do
    register_devices(devices_file: "./fastlane/devices.txt")
  end

  desc "Sync code signing certificates"
  lane :sync_signing do
    # Uncomment and configure match when ready:
    # match(type: "appstore")
    # match(type: "development")
    UI.message("Configure match in Matchfile when ready for automated signing")
  end

end
