rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // USERS
    // ============================================================
    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null && request.auth.uid == userId;

      allow update: if request.auth != null
        && (request.auth.uid == userId
            || onlyFriendIdsChanged()
            || onlyFcmTokenChanged(userId));

      allow delete: if false;
    }

    // ============================================================
    // FRIEND REQUESTS
    // ============================================================
    match /friend_requests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.from_user_id == request.auth.uid
            || resource.data.to_user_id == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.from_user_id == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if request.auth != null
        && resource.data.to_user_id == request.auth.uid;

      allow delete: if false;
    }

    // ============================================================
    // GAMES
    // ============================================================
    match /games/{gameId} {
      allow read: if request.auth != null;

      // Any authenticated user can create a game (they become the host)
      allow create: if request.auth != null
        && request.resource.data.host_id == request.auth.uid
        && request.resource.data.state == 'waiting';

      // Only the host can update the game while it's in 'waiting' state.
      // Game state transitions (waiting→in_progress, in_progress→finished)
      // and winning_team are handled exclusively by Cloud Functions
      // via the Admin SDK (bypasses these rules).
      allow update: if request.auth != null
        && resource.data.host_id == request.auth.uid
        && resource.data.state == 'waiting'
        && request.resource.data.state == 'waiting'
        && isOnlyAddingSelfToPlayerIds() == false;

      // Players can add themselves to player_ids when joining
      allow update: if request.auth != null
        && isOnlyAddingSelfToPlayerIds();

      // Only the host can delete the game (lobby disbandment)
      allow delete: if request.auth != null
        && resource.data.host_id == request.auth.uid;

      // ----------------------------------------------------------
      // PLAYERS (subcollection of games)
      // ----------------------------------------------------------
      match /players/{playerId} {
        // Authenticated users can read player docs, but role and
        // identity_card_id are only meaningful for:
        //   - The player themselves (user_id matches)
        //   - Unveiled players (is_unveiled == true)
        //   - Leaders (role == 'leader', always visible)
        // Client-side canSeeRole() enforces display; the server
        // enforces that clients cannot WRITE roles.
        allow read: if request.auth != null;

        // Players can add themselves to a game
        allow create: if request.auth != null
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.role == null
          && request.resource.data.identity_card_id == null;

        // Players can ONLY update their own unveil status (true only).
        // Life, elimination, role assignment, and card assignment are
        // handled exclusively by Cloud Functions.
        // Note: unveilPlayer Cloud Function also handles this, but
        // we keep the rule for backwards compat during migration.
        allow update: if request.auth != null
          && resource.data.user_id == request.auth.uid
          && onlyUnveilChanged();

        // Players can remove themselves, or the host can remove anyone (lobby only)
        allow delete: if request.auth != null
          && (resource.data.user_id == request.auth.uid
              || isGameHost(gameId));
      }
    }

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isGameHost(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data.host_id == request.auth.uid;
    }

    function isOnlyAddingSelfToPlayerIds() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['player_ids', 'last_activity_at'])
        && request.auth.uid in request.resource.data.player_ids;
    }

    function onlyFriendIdsChanged() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['friend_ids']);
    }

    function onlyFcmTokenChanged(userId) {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['fcm_token'])
        && request.auth.uid == userId;
    }

    // Returns true when only is_unveiled is changed (and only to true)
    function onlyUnveilChanged() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['is_unveiled'])
        && request.resource.data.is_unveiled == true;
    }
  }
}
